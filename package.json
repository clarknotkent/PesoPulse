{
  "name": "pesopulse",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "install:all": "npm install && npx nuxt prepare && cd api && python -m venv venv && venv\\Scripts\\pip install -r requirements.txt",
    "dev": "concurrently --names \"NUXT,FASTAPI\" --prefix-colors \"cyan,yellow\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "nuxt dev",
    "dev:backend": "cd api && venv\\Scripts\\python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "build": "nuxt build",
    "build:frontend": "nuxt build",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:py": "cd api && venv\\Scripts\\ruff check .",
    "lint:py:fix": "cd api && venv\\Scripts\\ruff check . --fix && venv\\Scripts\\ruff format .",
    "lint:all": "npm run lint && npm run lint:py",
    "lint:all:fix": "npm run lint:fix && npm run lint:py:fix"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.13.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vite-pwa/nuxt": "^0.10.6",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.0",
    "nuxt": "^3.17.7"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^12.13.0",
    "lucide-vue-next": "^1.0.0",
    "vue-chartjs": "^5.3.3"
  }
}
